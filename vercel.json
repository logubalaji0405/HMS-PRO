{
  "version": 2,
  "builds": [
    {
      "src": "hospital_project/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "hospital_project/wsgi.py"
    }
  ],
  "crons": [
    {
      "path": "/api/send-reminders",
      "schedule": "0 8 * * *"
    }
  ]
}